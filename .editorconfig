# Verify settings
[*.{received,verified}.{json,txt,xml}]
charset = "utf-8-bom"
end_of_line = lf
indent_size = unset
indent_style = unset
insert_final_newline = false
tab_width = unset
trim_trailing_whitespace = false

# Consider calling ConfigureAwait on the awaited task
[tests/**/*.cs]
dotnet_diagnostic.CA2007.severity = none